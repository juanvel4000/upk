EOF
        ;;
    verify)
        verify "$2"
        ;;
    version)
        echo "The Unnamed PacKage manager"
        echo "                           v$upk_version"       
        echo "                           UPK Is Licensed under the MIT License"
        echo "                           Please review \"upk license\""
        echo "                           Copyright (c) juanvel400"
        ;;
    extract)
        is_root
        if [ -z "$3" ]; then
            installroot="/"
        fi
        extract "$2"
        ;;
    install)
        is_root
        if [ -z "$3" ]; then
            installroot="/"
        fi
        extract "$2"
        install "$2" "/"
        ;;
    add)
        is_root
        install "$2" "$3"
        ;;
    query)
        query "$2"
        ;;
    remove)
        if [ -z "$3" ]; then
            installroot="/"
        fi
        uninstall "$2" "$installroot"
        ;;
    clear)
        clean
        ;;
    *)
        echo "Usage: upk <command>"
        ;;
esac